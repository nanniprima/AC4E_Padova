{
  "name": "ac4e-lse-phd-students",
  "version": "0.1.0",
  "private": true,
  "description": "Four-hour Agentic Coding for Economists short course for LSE PhD students.",
  "scripts": {
    "serve:form": "python3 -m http.server 8000 --directory examples/web-form",
    "pw:codegen": "playwright codegen http://localhost:8000",
    "pw:test": "playwright test",
    "validate": "python3 scripts/validate_setup.py",
    "docs:prebuild": "python3 scripts/build_site_tabs.py && python3 scripts/build_concepts_site.py",
    "docs:dev": "npm --prefix website run dev",
    "docs:build": "npm --prefix website run build",
    "slides:build": "cd slides/workshop && latexmk -pdf -interaction=nonstopmode workshop_slides.tex"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0"
  }
}

