# Example Codex MCP registration for a FRED/public-data metadata server.
# Copy only the relevant block into .codex/config.toml.
# Keep API keys in the environment; do not commit secrets.
#
# Official docs checked 2026-06-24: https://developers.openai.com/codex/mcp/

[mcp_servers.fred]
command = "python3"
args = ["-m", "fred_mcp_server"]
env_vars = ["FRED_API_KEY"]
cwd = "."

[mcp_servers.fred.env]
PYTHONPATH = "agent-harness/mcp/fred/src"

# Teaching note:
# - The bundled server lives in agent-harness/mcp/fred/.
# - Without FRED_API_KEY it returns offline teaching samples for smoke tests.
# - A Card-Krueger task can use FRED metadata for macro context, but the bundled
#   synthetic panel remains the only runnable local dataset in this repo.
