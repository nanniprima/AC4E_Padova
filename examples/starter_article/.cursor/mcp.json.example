{
  "_comment": "Example Cursor MCP config for the bundled FRED/public-data MCP server. Copy to .cursor/mcp.json. Keep FRED_API_KEY in the environment; do not commit secrets. Without a key, the server can return offline teaching samples. Cursor Cloud Agent uses team MCP settings, not this local file.",
  "mcpServers": {
    "fred": {
      "type": "stdio",
      "command": "python3",
      "args": ["-m", "fred_mcp_server"],
      "env": {
        "FRED_API_KEY": "${env:FRED_API_KEY}",
        "PYTHONPATH": "${workspaceFolder}/agent-harness/mcp/fred/src"
      }
    }
  }
}
